<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Ravindhar V – Resume</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ink:#1a1612;--ink2:#4a4540;--ink3:#8a7f78;
  --paper:#f5f1ec;--paper2:#ede8e1;
  --accent:#b94a2c;--accent2:#d4703a;
  --border:rgba(26,22,18,0.13);
  --green:#2d6a2d;--green-bg:#edf7ed;--green-bd:#b8ddb8;
  --font-serif:'Playfair Display',Georgia,serif;
  --font-sans:'Jost',sans-serif;
}
body{font-family:var(--font-sans);background:var(--paper);color:var(--ink);min-height:100vh;}

/* HEADER */
header{background:var(--ink);color:var(--paper);padding:3rem 2.5rem 2.5rem;position:relative;overflow:hidden;}
header::before{content:'';position:absolute;top:-60px;right:-60px;width:260px;height:260px;border-radius:50%;border:40px solid rgba(185,74,44,0.18);}
header::after{content:'';position:absolute;bottom:-40px;left:120px;width:180px;height:180px;border-radius:50%;border:28px solid rgba(185,74,44,0.10);}
.header-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;}
.name-block h1{font-family:var(--font-serif);font-size:clamp(2.2rem,4vw,3.4rem);font-weight:600;color:#fff;line-height:1.05;}
.name-block h1 em{font-style:italic;color:var(--accent2);}
.tagline{font-size:0.78rem;letter-spacing:0.18em;text-transform:uppercase;color:rgba(245,241,236,0.5);margin-top:8px;font-weight:300;}
.contact-strip{display:flex;flex-wrap:wrap;gap:6px 20px;margin-top:1.2rem;}
.contact-strip a,.contact-strip span{font-size:0.8rem;color:rgba(245,241,236,0.72);text-decoration:none;display:flex;align-items:center;gap:5px;}
.contact-strip a:hover{color:var(--accent2);}
.ci{width:13px;height:13px;fill:var(--accent);flex-shrink:0;}

/* LAYOUT */
.page{max-width:1200px;margin:0 auto;padding:2rem 1.5rem;display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start;}
.main{display:flex;flex-direction:column;gap:1.8rem;}
.sidebar{display:flex;flex-direction:column;gap:1.5rem;}

/* SECTION HEAD */
.sec-head{font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--accent);font-weight:500;margin-bottom:1rem;padding-bottom:7px;border-bottom:1.5px solid var(--accent);display:flex;align-items:center;justify-content:space-between;}
.sec-head-left{display:flex;align-items:center;gap:8px;}
.sec-head svg.si{width:13px;height:13px;fill:var(--accent);}
.btn-group{display:flex;gap:6px;align-items:center;flex-wrap:wrap;}
.add-btn{font-family:var(--font-sans);font-size:0.72rem;padding:4px 12px;border-radius:99px;border:1px dashed var(--accent);background:transparent;color:var(--accent);cursor:pointer;font-weight:500;display:flex;align-items:center;gap:4px;transition:all 0.15s;white-space:nowrap;}
.add-btn:hover{background:var(--accent);color:#fff;}

/* ABOUT */
.about-wrapper{position:relative;}
.about-text{font-size:0.94rem;line-height:1.8;color:var(--ink2);font-weight:300;border:1.5px solid transparent;border-radius:8px;padding:10px 12px;transition:border-color 0.2s,background 0.2s;outline:none;min-height:60px;}
.about-text[contenteditable="true"]:hover{border-color:var(--border);background:rgba(255,255,255,0.5);}
.about-text[contenteditable="true"]:focus{border-color:var(--accent);background:#fff;}
.about-edit-hint{font-size:0.72rem;color:var(--ink3);margin-top:5px;display:flex;align-items:center;gap:5px;padding-left:12px;}
.about-edit-hint svg{width:11px;height:11px;fill:var(--ink3);}

/* JOB */
.job{margin-bottom:1.4rem;padding-bottom:1.4rem;border-bottom:0.5px solid var(--border);position:relative;}
.job:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.job-header{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;}
.job-title{font-family:var(--font-serif);font-size:1rem;font-weight:600;}
.job-date{font-size:0.73rem;background:var(--paper2);border:1px solid var(--border);padding:3px 10px;border-radius:99px;color:var(--ink3);white-space:nowrap;flex-shrink:0;}
.job-company{font-size:0.8rem;color:var(--accent);font-weight:500;margin:3px 0;letter-spacing:0.03em;}
.job-bullets{list-style:none;margin-top:7px;display:flex;flex-direction:column;gap:4px;}
.job-bullets li{font-size:0.86rem;color:var(--ink2);font-weight:300;line-height:1.6;padding-left:14px;position:relative;}
.job-bullets li::before{content:'–';position:absolute;left:0;color:var(--accent);}
.job-actions{display:flex;gap:6px;margin-top:10px;padding-top:8px;border-top:0.5px dashed var(--border);}
.job-btn{font-family:var(--font-sans);font-size:0.72rem;padding:4px 12px;border-radius:6px;cursor:pointer;font-weight:500;transition:all 0.15s;display:inline-flex;align-items:center;gap:4px;border:1px solid var(--border);background:#fff;color:var(--ink2);}
.job-btn:hover{border-color:var(--accent);color:var(--accent);}
.job-btn.danger{color:#c0392b;border-color:#e8b4b0;}
.job-btn.danger:hover{background:#fdf0ef;}
.job-btn svg{width:11px;height:11px;fill:currentColor;}

/* EDU */
.edu-item{margin-bottom:1rem;padding-bottom:1rem;border-bottom:0.5px solid var(--border);position:relative;}
.edu-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.edu-deg{font-family:var(--font-serif);font-size:1rem;font-weight:600;}
.edu-school{font-size:0.8rem;color:var(--accent);margin:2px 0;font-weight:500;}
.edu-meta{font-size:0.78rem;color:var(--ink3);}

/* SKILLS */
.skills-groups{display:flex;flex-direction:column;gap:10px;}
.skill-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.skill-cat{font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink3);min-width:60px;font-weight:500;}
.skill-pills{display:flex;flex-wrap:wrap;gap:5px;}
.pill{font-size:0.76rem;padding:3px 11px;border:1px solid var(--border);border-radius:99px;color:var(--ink2);background:var(--paper2);font-weight:400;}
.pill.strong{background:var(--ink);color:var(--paper);border-color:var(--ink);}

/* ACHIEVEMENTS */
.ach-list{list-style:none;display:flex;flex-direction:column;gap:6px;}
.ach-list li{font-size:0.86rem;color:var(--ink2);font-weight:300;line-height:1.5;padding-left:18px;position:relative;}
.ach-list li::before{content:'★';position:absolute;left:0;font-size:0.62rem;color:var(--accent);top:3px;}

/* SIDEBAR CARD */
.sidebar-card{background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.sidebar-card-head{background:var(--ink);color:var(--paper);font-size:0.67rem;letter-spacing:0.16em;text-transform:uppercase;font-weight:500;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;}
.sidebar-card-head svg{width:13px;height:13px;fill:var(--accent2);}
.sidebar-card-head-left{display:flex;align-items:center;gap:8px;}
.sidebar-add-btn{font-family:var(--font-sans);font-size:0.68rem;padding:3px 10px;border-radius:99px;border:1px dashed rgba(255,255,255,0.4);background:transparent;color:rgba(255,255,255,0.8);cursor:pointer;transition:all 0.15s;}
.sidebar-add-btn:hover{background:rgba(255,255,255,0.15);}
.sidebar-card-body{padding:14px 16px;}

/* PROJECT FILE */
.proj-file{border:1px solid var(--border);border-radius:8px;padding:11px 13px;margin-bottom:9px;background:var(--paper);transition:border-color 0.2s;position:relative;}
.proj-file:last-child{margin-bottom:0;}
.proj-file:hover{border-color:var(--accent);}
.proj-file-name{font-size:0.87rem;font-weight:500;color:var(--ink);margin-bottom:3px;}
.proj-file-desc{font-size:0.77rem;color:var(--ink3);line-height:1.5;margin-bottom:7px;}
.file-badge{display:none;align-items:center;gap:5px;font-size:0.72rem;padding:3px 9px;border-radius:99px;background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd);margin-bottom:6px;}
.proj-file-actions{display:flex;gap:6px;flex-wrap:wrap;}
.btn-attach{font-family:var(--font-sans);font-size:0.74rem;padding:5px 11px;border-radius:6px;cursor:pointer;font-weight:500;transition:all 0.15s;display:inline-flex;align-items:center;gap:5px;border:1px solid var(--border);background:#fff;color:var(--ink2);}
.btn-attach:hover{border-color:var(--accent);color:var(--accent);}
.btn-attach.primary{background:var(--accent);color:#fff;border-color:var(--accent);}
.btn-attach.primary:hover{background:#a03820;}
.btn-attach.danger{color:#c0392b;border-color:#e8b4b0;}
.btn-attach.danger:hover{background:#fdf0ef;}
input[type="file"]{display:none;}

/* CERT */
.cert-item{padding:8px 0;border-bottom:0.5px solid var(--border);font-size:0.84rem;color:var(--ink2);line-height:1.5;display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.cert-item:last-child{border-bottom:none;}
.cert-tag{display:inline-block;font-size:0.67rem;padding:2px 8px;background:var(--paper2);border-radius:4px;color:var(--ink3);margin-top:3px;}

/* LANG */
.lang-row{display:flex;gap:7px;flex-wrap:wrap;padding:4px 0;}
.lang-chip{font-size:0.81rem;padding:5px 14px;border-radius:99px;border:1px solid var(--border);color:var(--ink2);background:var(--paper2);display:flex;align-items:center;gap:6px;}

/* CUSTOM */
.custom-item{padding:8px 0;border-bottom:0.5px solid var(--border);font-size:0.84rem;color:var(--ink2);display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.custom-item:last-child{border-bottom:none;}

/* NEW SECTION */
.new-section-box{border:1.5px dashed var(--border);border-radius:12px;padding:1.2rem;text-align:center;cursor:pointer;transition:all 0.2s;background:transparent;}
.new-section-box:hover{border-color:var(--accent);background:#fff8f6;}
.new-section-box p{font-size:0.82rem;color:var(--ink3);margin-top:6px;}
.new-section-box svg{fill:var(--ink3);width:22px;height:22px;}

/* REMOVE */
.remove-btn{font-size:0.7rem;padding:2px 8px;border-radius:4px;border:1px solid #e8b4b0;background:transparent;color:#c0392b;cursor:pointer;flex-shrink:0;font-family:var(--font-sans);}
.remove-btn:hover{background:#fdf0ef;}

/* ── MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#fff;border-radius:14px;padding:1.8rem;width:min(540px,94vw);max-height:90vh;overflow-y:auto;position:relative;}
.modal h3{font-family:var(--font-serif);font-size:1.25rem;margin-bottom:1.2rem;color:var(--ink);}
.modal label{display:block;font-size:0.75rem;letter-spacing:0.07em;text-transform:uppercase;color:var(--ink3);margin:12px 0 5px;font-weight:500;}
.modal label:first-of-type{margin-top:0;}
.modal input[type="text"],.modal textarea,.modal select{width:100%;border:1px solid var(--border);border-radius:8px;padding:9px 12px;font-family:var(--font-sans);font-size:0.9rem;color:var(--ink);background:var(--paper);outline:none;transition:border-color 0.2s;}
.modal input[type="text"]:focus,.modal textarea:focus{border-color:var(--accent);}
.modal textarea{resize:vertical;min-height:90px;line-height:1.6;}
.modal-hint{font-size:0.76rem;color:var(--ink3);margin-top:4px;}
.modal-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:1.4rem;}
.modal-actions button{font-family:var(--font-sans);font-size:0.84rem;padding:8px 20px;border-radius:8px;cursor:pointer;font-weight:500;transition:all 0.15s;}
.btn-cancel{background:transparent;border:1px solid var(--border);color:var(--ink3);}
.btn-cancel:hover{border-color:var(--ink3);}
.btn-save{background:var(--accent);color:#fff;border:1px solid var(--accent);}
.btn-save:hover{background:#a03820;}

/* EDIT HIGHLIGHT */
[contenteditable="true"]{outline:none;}
.editable-field{border:1.5px solid transparent;border-radius:6px;padding:3px 7px;transition:border-color 0.18s,background 0.18s;cursor:text;}
.editable-field:hover{border-color:rgba(185,74,44,0.35);background:rgba(255,255,255,0.6);}
.editable-field:focus{border-color:var(--accent);background:#fff;outline:none;}

@media(max-width:780px){.page{grid-template-columns:1fr;}header{padding:2rem 1.2rem;}}
</style>
</head>
<body>

<!-- ══ MODALS ══ -->

<!-- EDIT EXPERIENCE -->
<div class="modal-overlay" id="modal-edit-exp">
  <div class="modal">
    <h3 id="edit-exp-heading">Edit Experience</h3>
    <label>Job Title</label>
    <input type="text" id="ee-title"/>
    <label>Company &amp; Location</label>
    <input type="text" id="ee-company"/>
    <label>Duration</label>
    <input type="text" id="ee-date" placeholder="e.g. Jun 2026 – Present"/>
    <label>Bullet Points <span class="modal-hint">(one per line)</span></label>
    <textarea id="ee-bullets" rows="7"></textarea>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-edit-exp')">Cancel</button>
      <button class="btn-save" onclick="applyEditExp()">Save Changes</button>
    </div>
  </div>
</div>

<!-- ADD EXPERIENCE -->
<div class="modal-overlay" id="modal-exp">
  <div class="modal">
    <h3>Add Experience</h3>
