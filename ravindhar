<script>
/* ── STATE ── */
let editingJobId = null;
let pfCount = 3;
let currentCustomTarget = 'main';
let currentCustomSectionId = null;
let jobCounter = 2;

/* ── MODAL HELPERS ── */
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if(e.target === o) o.classList.remove('open'); });
});

/* ── EDIT EXPERIENCE (existing jobs) ── */
function openEditExp(jobId) {
  editingJobId = jobId;
  const title = document.getElementById(jobId+'-title').textContent;
  const company = document.getElementById(jobId+'-company').textContent;
  const date = document.getElementById(jobId+'-date').textContent;
  const bullets = Array.from(document.getElementById(jobId+'-bullets').querySelectorAll('li'))
    .map(li => li.textContent.trim()).join('\n');

  document.getElementById('ee-title').value = title;
  document.getElementById('ee-company').value = company;
  document.getElementById('ee-date').value = date;
  document.getElementById('ee-bullets').value = bullets;
  document.getElementById('edit-exp-heading').textContent = 'Edit: ' + title;
  openModal('modal-edit-exp');
}

function applyEditExp() {
  if(!editingJobId) return;
  const title = document.getElementById('ee-title').value.trim();
  const company = document.getElementById('ee-company').value.trim();
  const date = document.getElementById('ee-date').value.trim();
  const bulletsRaw = document.getElementById('ee-bullets').value;

  if(title) document.getElementById(editingJobId+'-title').textContent = title;
  if(company) document.getElementById(editingJobId+'-company').innerHTML = company;
  if(date) document.getElementById(editingJobId+'-date').textContent = date;

  const bulletsEl = document.getElementById(editingJobId+'-bullets');
  bulletsEl.innerHTML = bulletsRaw.split('\n')
    .filter(l => l.trim())
    .map(l => `<li>${l.trim()}</li>`)
    .join('');

  closeModal('modal-edit-exp');
  editingJobId = null;
}

/* ── ADD EXPERIENCE ── */
function saveExp() {
  const t = v('exp-title'), c = v('exp-company'), d = v('exp-date'), b = v('exp-bullets');
  if(!t) return;
  jobCounter++;
  const jid = 'j' + jobCounter;
  const bullets = b.split('\n').filter(x=>x.trim()).map(x=>`<li>${x.trim()}</li>`).join('');
  const html = `<div class="job" data-jobid="${jid}">
    <div class="job-header">
      <div>
        <div class="job-title" id="${jid}-title">${t}</div>
        <div class="job-company" id="${jid}-company">${c}</div>
      </div>
      <span class="job-date" id="${jid}-date">${d}</span>
    </div>
    <ul class="job-bullets" id="${jid}-bullets">${bullets}</ul>
    <div class="job-actions">
      <button class="job-btn" onclick="openEditExp('${jid}')">
        <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
        Edit
      </button>
      <button class="job-btn danger" onclick="this.closest('.job').remove()">
        <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
        Remove
      </button>
    </div>
  </div>`;
  document.getElementById('exp-list').insertAdjacentHTML('beforeend', html);
  clearFields(['exp-title','exp-company','exp-date','exp-bullets']);
  closeModal('modal-exp');
}

/* ── EDUCATION ── */
function saveEdu() {
  const d=v('edu-deg'),s=v('edu-school'),m=v('edu-meta');
  if(!d) return;
  const html = `<div class="edu-item">
    <div class="edu-deg">${d}</div>
    <div class="edu-school">${s}</div>
    <div class="edu-meta">${m}</div>
    <button class="remove-btn" style="margin-top:6px" onclick="this.closest('.edu-item').remove()">✕ Remove</button>
  </div>`;
  document.getElementById('edu-list').insertAdjacentHTML('beforeend', html);
  clearFields(['edu-deg','edu-school','edu-meta']);
  closeModal('modal-edu');
}

/* ── SKILLS ── */
function saveSkill() {
  const cat=v('skill-cat'),items=v('skill-items'),style=document.getElementById('skill-style').value;
  if(!cat||!items) return;
  const safeId = 'sr-'+cat.replace(/\s+/g,'-');
  const pills = items.split(',').map(s=>`<span class="pill ${style}">${s.trim()}</span>`).join('');
  const existing = document.getElementById(safeId);
  if(existing){
    existing.querySelector('.skill-pills').insertAdjacentHTML('beforeend', pills);
  } else {
    const html = `<div class="skill-row" id="${safeId}">
      <span class="skill-cat">${cat}</span>
      <div class="skill-pills">${pills}</div>
      <button class="remove-btn" onclick="this.closest('.skill-row').remove()">✕</button>
    </div>`;
    document.getElementById('skills-list').insertAdjacentHTML('beforeend', html);
  }
  clearFields(['skill-cat','skill-items']);
  document.getElementById('skill-style').value = '';
  closeModal('modal-skill');
}

/* ── ACHIEVEMENTS ── */
function saveAch() {
  const t=v('ach-text'); if(!t) return;
  const li = document.createElement('li');
  li.innerHTML = `${t} <button class="remove-btn" onclick="this.closest('li').remove()">✕</button>`;
  document.getElementById('ach-list').appendChild(li);
  clearFields(['ach-text']);
  closeModal('modal-ach');
}

/* ── CERTIFICATIONS ── */
function saveCert() {
  const n=v('cert-name'),i=v('cert-issuer'); if(!n) return;
  const html = `<div class="cert-item">
    <div>${n}${i?`<br/><span class="cert-tag">${i}</span>`:''}</div>
    <button class="remove-btn" onclick="this.closest('.cert-item').remove()">✕</button>
  </div>`;
  document.getElementById('cert-list').insertAdjacentHTML('beforeend', html);
  clearFields(['cert-name','cert-issuer']);
  closeModal('modal-cert');
}

/* ── LANGUAGES ── */
function saveLang() {
  const n=v('lang-name'),l=v('lang-level'); if(!n) return;
  const chip = document.createElement('span');
  chip.className = 'lang-chip';
  chip.innerHTML = `${n}${l?` <small style="color:var(--ink3);font-size:0.7rem">(${l})</small>`:''} <button style="border:none;background:transparent;color:var(--ink3);cursor:pointer;font-size:0.65rem;padding:0 0 0 4px;" onclick="this.closest('.lang-chip').remove()">✕</button>`;
  document.getElementById('lang-list').appendChild(chip);
  clearFields(['lang-name','lang-level']);
  closeModal('modal-lang');
}

/* ── PROJECTS ── */
function saveProj() {
  const t=v('proj-title'),d=v('proj-desc'); if(!t) return;
  pfCount++;
  const bid='pb'+pfCount, nid='pn'+pfCount, fid='fi'+pfCount;
  const html = `<div class="proj-file">
    <div class="proj-file-name">${t}</div>
    <div class="proj-file-desc">${d}</div>
    <div id="${bid}" class="file-badge"><svg style="width:12px;height:12px;fill:var(--green)" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg><span id="${nid}"></span></div>
    <div class="proj-file-actions">
      <label class="btn-attach primary" for="${fid}"><svg style="width:11px;height:11px;fill:#fff" viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg> Attach</label>
      <input type="file" id="${fid}" accept=".pdf,.docx,.pptx,.zip,.png,.jpg" onchange="attachFile(this,'${bid}','${nid}')"/>
      <button class="btn-attach danger" onclick="this.closest('.proj-file').remove()">Remove</button>
    </div>
  </div>`;
  document.getElementById('proj-list').insertAdjacentHTML('beforeend', html);
  clearFields(['proj-title','proj-desc']);
  closeModal('modal-proj');
}

/* ── CUSTOM SECTIONS ── */
function openCustomSectionModal(target){ currentCustomTarget=target; openModal('modal-custom-section'); }

function saveCustomSection() {
  const title=v('custom-sec-title'); if(!title) return;
  const secId='cs-'+Date.now();
  currentCustomSectionId = secId;
  if(currentCustomTarget==='main'){
    const html=`<div class="section" id="${secId}">
      <div class="sec-head">
        <div class="sec-head-left"><svg class="si" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>${title}</div>
        <div style="display:flex;gap:6px">
          <button class="add-btn" onclick="openCustomItemModal('${secId}','${title}')">+ Add</button>
          <button class="add-btn" style="border-color:#c0392b;color:#c0392b" onclick="document.getElementById('${secId}').remove()">Remove section</button>
        </div>
      </div>
      <div id="${secId}-items" class="ach-list"></div>
    </div>`;
    document.getElementById('main-custom-sections').insertAdjacentHTML('beforeend',html);
  } else {
    const html=`<div class="sidebar-card" id="${secId}">
      <div class="sidebar-card-head">
        <div class="sidebar-card-head-left"><svg viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>${title}</div>
        <div style="display:flex;gap:4px">
          <button class="sidebar-add-btn" onclick="openCustomItemModal('${secId}','${title}')">+ Add</button>
          <button class="sidebar-add-btn" style="border-color:#e8b4b0;color:#f4a39e;" onclick="document.getElementById('${secId}').remove()">✕</button>
        </div>
      </div>
      <div class="sidebar-card-body"><div id="${secId}-items"></div></div>
    </div>`;
    document.getElementById('sidebar-custom-sections').insertAdjacentHTML('beforeend',html);
  }
  clearFields(['custom-sec-title']);
  closeModal('modal-custom-section');
}

function openCustomItemModal(secId,secTitle){
  currentCustomSectionId=secId;
  document.getElementById('custom-item-title').textContent='Add to '+secTitle;
  openModal('modal-custom-item');
}

function saveCustomItem(){
  const n=v('custom-item-name'),d=v('custom-item-detail');
  if(!n||!currentCustomSectionId) return;
  const container=document.getElementById(currentCustomSectionId+'-items');
  if(!container) return;
  const html=`<div class="custom-item">
    <div><strong style="font-size:0.86rem;font-weight:500">${n}</strong>${d?`<br/><span style="font-size:0.78rem;color:var(--ink3)">${d}</span>`:''}</div>
    <button class="remove-btn" onclick="this.closest('.custom-item').remove()">✕</button>
  </div>`;
  container.insertAdjacentHTML('beforeend',html);
  clearFields(['custom-item-name','custom-item-detail']);
  closeModal('modal-custom-item');
}

/* ── FILE ATTACH ── */
function attachFile(input,badgeId,nameId){
  if(!input.files||!input.files[0]) return;
  const badge=document.getElementById(badgeId);
  document.getElementById(nameId).textContent=input.files[0].name;
  badge.style.display='inline-flex';
}

/* ── UTILS ── */
function v(id){ return document.getElementById(id).value.trim(); }
function clearFields(ids){ ids.forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; }); }
</script>
</body>
</html>
