      <button class="btn-cancel" onclick="closeModal('modal-exp')">Cancel</button>
      <button class="btn-save" onclick="saveExp()">Add</button>
    </div>
  </div>
</div>

<!-- ADD EDUCATION -->
<div class="modal-overlay" id="modal-edu">
  <div class="modal">
    <h3>Add Education</h3>
    <label>Degree / Qualification</label><input type="text" id="edu-deg" placeholder="e.g. B.E. Mechanical Engineering"/>
    <label>Institution</label><input type="text" id="edu-school" placeholder="e.g. VCET, Thindal, TN"/>
    <label>Year &amp; Score</label><input type="text" id="edu-meta" placeholder="e.g. 2021–2025 · CGPA: 8.78"/>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-edu')">Cancel</button>
      <button class="btn-save" onclick="saveEdu()">Add</button>
    </div>
  </div>
</div>

<!-- ADD SKILL -->
<div class="modal-overlay" id="modal-skill">
  <div class="modal">
    <h3>Add Skill</h3>
    <label>Category</label><input type="text" id="skill-cat" placeholder="e.g. Programming"/>
    <label>Skills <span class="modal-hint">(comma separated)</span></label><input type="text" id="skill-items" placeholder="e.g. Python, MATLAB, C++"/>
    <label>Style</label>
    <select id="skill-style"><option value="">Normal</option><option value="strong">Bold (highlight)</option></select>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-skill')">Cancel</button>
      <button class="btn-save" onclick="saveSkill()">Add</button>
    </div>
  </div>
</div>

<!-- ADD ACHIEVEMENT -->
<div class="modal-overlay" id="modal-ach">
  <div class="modal">
    <h3>Add Achievement</h3>
    <label>Achievement</label>
    <textarea id="ach-text" placeholder="e.g. 1st Place – National Design Competition 2025"></textarea>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-ach')">Cancel</button>
      <button class="btn-save" onclick="saveAch()">Add</button>
    </div>
  </div>
</div>

<!-- ADD CERTIFICATION -->
<div class="modal-overlay" id="modal-cert">
  <div class="modal">
    <h3>Add Certification</h3>
    <label>Certification Name</label><input type="text" id="cert-name" placeholder="e.g. Six Sigma Green Belt"/>
    <label>Issuer / Platform</label><input type="text" id="cert-issuer" placeholder="e.g. IIT NPTEL, Coursera"/>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-cert')">Cancel</button>
      <button class="btn-save" onclick="saveCert()">Add</button>
    </div>
  </div>
</div>

<!-- ADD LANGUAGE -->
<div class="modal-overlay" id="modal-lang">
  <div class="modal">
    <h3>Add Language</h3>
    <label>Language</label><input type="text" id="lang-name" placeholder="e.g. Hindi"/>
    <label>Proficiency <span class="modal-hint">(optional)</span></label><input type="text" id="lang-level" placeholder="e.g. Native, Conversational"/>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-lang')">Cancel</button>
      <button class="btn-save" onclick="saveLang()">Add</button>
    </div>
  </div>
</div>

<!-- ADD PROJECT -->
<div class="modal-overlay" id="modal-proj">
  <div class="modal">
    <h3>Add Project</h3>
    <label>Project Title</label><input type="text" id="proj-title" placeholder="e.g. Robotic Arm Design"/>
    <label>Description</label><textarea id="proj-desc" placeholder="Brief description..."></textarea>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-proj')">Cancel</button>
      <button class="btn-save" onclick="saveProj()">Add</button>
    </div>
  </div>
</div>

<!-- CUSTOM SECTION -->
<div class="modal-overlay" id="modal-custom-section">
  <div class="modal">
    <h3>Add Custom Section</h3>
    <label>Section Title</label><input type="text" id="custom-sec-title" placeholder="e.g. Publications, Volunteering"/>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-custom-section')">Cancel</button>
      <button class="btn-save" onclick="saveCustomSection()">Create</button>
    </div>
  </div>
</div>

<!-- CUSTOM ITEM -->
<div class="modal-overlay" id="modal-custom-item">
  <div class="modal">
    <h3 id="custom-item-title">Add Item</h3>
    <label>Title / Name</label><input type="text" id="custom-item-name" placeholder="Item title"/>
    <label>Detail <span class="modal-hint">(optional)</span></label><input type="text" id="custom-item-detail" placeholder="Additional info"/>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('modal-custom-item')">Cancel</button>
      <button class="btn-save" onclick="saveCustomItem()">Add</button>
    </div>
  </div>
</div>

